{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADB Uninstaller",
  "version": "2.0.0",
  "identifier": "com.megapass.adbuninstaller",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ADB Uninstaller - By Teknisi Megapass Sidoarjo",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["android-tools-adb"]
      }
    },
    "shortDescription": "Manage Android apps via ADB",
    "longDescription": "ADB Uninstaller for technicians - debloat, uninstall, disable apps with AI safety analysis. By Teknisi Megapass Sidoarjo."
  }
}
